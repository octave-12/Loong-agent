# 龙珠 LoongPearl — .gitignore

# ── 模型文件（太大，不纳入 git）──
*.pt

# ── 运行时产物（进度/缓存/参数）──
data/runtime/*.json

# ── 播种进度和结果（大量 JSON）──
scripts/seed/*.json

# ── Python ──
__pycache__/
*.pyc
*.pyo

# ── 音频文件（太多太大）──
ref_audio/
sounds/

# ── 日志 ──
logs/

# ── 论文/文档（暂时不入 git）──
doc/

# ── 虚拟环境 ──
.venv/
venv/

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo

# ── Jupyter ──
.ipynb_checkpoints/

# ── OS ──
.DS_Store
Thumbs.db

# ── 缓存 ──
.dict_cache/
.vis_cache/
