# 龙珠 LoongPearl — .gitignore

# ── 模型文件（太大，不纳入 git）──
*.pt

# ── 运行时产物（进度/缓存/参数）──
data/runtime/*.json

# ── 播种进度和结果（大量 JSON）──
scripts/seed/*.json

# ── Python ──
__pycache__/
*.pyc
*.pyo

# ── 音频文件（太多太大）──
ref_audio/
sounds/

# ── 日志 ──
logs/

# ── 论文/文档（暂时不入 git）──
doc/

# ── 虚拟环境 ──
.venv/
venv/

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo

# ── Jupyter ──
.ipynb_checkpoints/

# ── OS ──
.DS_Store
Thumbs.db

# ── 缓存 ──
.dict_cache/
.vis_cache/
data/models/concept_graph.json
data/models/concept_graph_embeds.pt
data/models/energy_pyramid.pt
data/models/energy_pyramid_deep.pt
data/models/energy_landscape_1024d.pt
data/models/*.pt.backup
data/models/*.bak
data/models/*.bak.*
data/models/*.db
data/models/*.db-shm
data/models/*.db-wal
data/models/*.safetensors
data/models/*.post_cg_inject
data/models/sequence_field.json
data/models/concept_graph.json
data/models/concept_graph.json.*
data/models/dragon_field_meta.json
data/instances/
data/wikipedia/
data/zhwikibooks.xml.bz2
data/zhwiktionary.xml.bz2

# ── 构建产物 ──
dist/

# ── 备份文件 ──
*.bak

# ── Hermes 计划文件 ──
.hermes/
.arts/

# ── 测试报告 ──
tests/scenario_report_*.json
